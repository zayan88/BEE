// COD E-commerce Funnel — Prisma schema
// Datasource: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================ AUTH / USERS ============================
enum Role {
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================ PRODUCTS ============================
model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  tagline         String?
  description     String?  @db.Text
  // Money stored in the smallest currency unit (e.g. Iraqi dinar) as integers.
  price           Int
  compareAtPrice  Int?
  currency        String   @default("IQD")
  currencySymbol  String   @default("د.ع")
  stock           Int      @default(0)
  active          Boolean  @default(true)
  // Shipping defaults for this product
  shippingFee     Int      @default(0)
  freeShippingQty Int?     // qty at/above which shipping is free (null = never)

  // Landing page content (flexible JSON blocks)
  heroBadge   String?
  rating      Float   @default(4.9)
  ratingCount Int     @default(0)
  content     Json?   // { benefits, ingredients, steps, whyus, problems, faq, socialProof, ... }

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  images    ProductImage[]
  variants  Variant[]
  bundles   Bundle[]
  reviews   Review[]
  offers    Offer[]
  upsells   Upsell[]       @relation("ProductUpsells")
  orderItems OrderItem[]
  events    AnalyticsEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int     @default(0)

  @@index([productId])
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String  // e.g. "50 غرام"
  sku       String? @unique
  price     Int?    // overrides product price when set
  stock     Int     @default(0)
  position  Int     @default(0)

  @@index([productId])
}

// A quantity-based bundle offer, e.g. "3 pieces for X, save Y"
model Bundle {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String  // "قطعة واحدة" / "قطعتان" / "ثلاث قطع"
  quantity   Int
  price      Int     // total price for the whole bundle
  compareAt  Int?    // strike-through reference total
  freeShipping Boolean @default(false)
  isPopular  Boolean @default(false)
  position   Int     @default(0)

  orders     Order[]

  @@index([productId])
}

// ============================ OFFERS ============================
enum OfferType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

model Offer {
  id         String    @id @default(cuid())
  productId  String?
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  code       String?   @unique
  title      String
  type       OfferType
  value      Int       @default(0) // percent (0-100) or fixed amount
  active     Boolean   @default(true)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([productId])
}

// ============================ UPSELLS ============================
enum UpsellTrigger {
  POST_ORDER
}

model Upsell {
  id             String        @id @default(cuid())
  productId      String
  product        Product       @relation("ProductUpsells", fields: [productId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  // Extra quantity of the same product offered
  extraQuantity  Int           @default(1)
  discountPercent Int          @default(0)
  freeShipping   Boolean       @default(false)
  price          Int           // final price for the upsell add-on
  compareAt      Int?
  trigger        UpsellTrigger @default(POST_ORDER)
  active         Boolean       @default(true)
  position       Int           @default(0)

  events         UpsellEvent[]
  createdAt      DateTime      @default(now())

  @@index([productId])
}

enum UpsellDecision {
  SHOWN
  ACCEPTED
  REJECTED
}

model UpsellEvent {
  id        String         @id @default(cuid())
  upsellId  String
  upsell    Upsell         @relation(fields: [upsellId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  decision  UpsellDecision
  createdAt DateTime       @default(now())

  @@index([upsellId])
  @@index([orderId])
}

// ============================ CUSTOMERS ============================
model Customer {
  id        String  @id @default(cuid())
  fullName  String
  phone     String  @unique
  province  String?
  city      String?
  address   String? @db.Text
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

// ============================ ORDERS ============================
enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @unique @default(autoincrement())

  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Snapshot of shipping details at time of order
  fullName    String
  phone       String
  province    String
  city        String?
  address     String      @db.Text

  bundleId    String?
  bundle      Bundle?     @relation(fields: [bundleId], references: [id], onDelete: SetNull)

  subtotal    Int
  discount    Int         @default(0)
  shipping    Int         @default(0)
  total       Int
  currency    String      @default("IQD")

  status      OrderStatus @default(PENDING)
  source      String      @default("landing") // e.g. landing / facebook / tiktok / google
  notes       String?     @db.Text

  hasUpsell   Boolean     @default(false)

  items       OrderItem[]
  upsellEvents UpsellEvent[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([province])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name       String
  unitPrice  Int
  quantity   Int
  isUpsell   Boolean @default(false)

  @@index([orderId])
}

// ============================ REVIEWS ============================
model Review {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author     String
  location   String?
  rating     Int     @default(5)
  body       String  @db.Text
  verified   Boolean @default(true)
  approved   Boolean @default(true)
  position   Int     @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
}

// ============================ TRACKING / PIXELS ============================
model TrackingSettings {
  id                String  @id @default("default")
  metaPixelId       String?
  tiktokPixelId     String?
  googleAnalyticsId String?
  googleTagManagerId String?
  snapchatPixelId   String?
  customHeadScripts String? @db.Text
  customBodyScripts String? @db.Text
  updatedAt         DateTime @updatedAt
}

// ============================ ANALYTICS ============================
enum AnalyticsEventType {
  PAGE_VIEW
  VIEW_CONTENT
  ADD_TO_CART
  INITIATE_CHECKOUT
  LEAD
  PURCHASE
  UPSELL_ACCEPTED
  UPSELL_REJECTED
  ORDER_SUBMITTED
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  type       AnalyticsEventType
  productId  String?
  product    Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  orderId    String?
  sessionId  String?
  value      Int                @default(0)
  province   String?
  source     String?
  path       String?
  userAgent  String?            @db.Text
  createdAt  DateTime           @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([productId])
}

// Site-wide settings (name, contact, shipping defaults, etc.)
model SiteSettings {
  id             String  @id @default("default")
  storeName      String  @default("متجر الدفع عند الاستلام")
  supportPhone   String?
  supportEmail   String?
  defaultShipping Int    @default(0)
  currency       String  @default("IQD")
  currencySymbol String  @default("د.ع")
  updatedAt      DateTime @updatedAt
}
